---
import { events, eventsHeading } from "../data/site";
import EventCard from "./EventCard.astro";

const featuredEvents = events.filter((e) => e.featured);
const allEvents = events;
---

<section class="py-20 bg-white dark:bg-slate-900" id="calendario">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12 gap-4">
      <div>
        <h2
          class="text-4xl md:text-6xl font-display uppercase text-primary dark:text-white leading-none"
        >
          {eventsHeading.title}
          <span class="text-gradient">
            {eventsHeading.ampersand}{eventsHeading.titleEnd}
          </span>
        </h2>
        <p class="mt-4 text-slate-600 dark:text-slate-400 max-w-lg">
          {eventsHeading.subtitle}
        </p>
      </div>
      <button
        id="toggle-events-btn-top"
        class="toggle-events-btn px-6 py-2 rounded-full border-2 border-primary dark:border-white text-primary dark:text-white font-bold text-sm uppercase tracking-wider hover:bg-primary hover:text-white dark:hover:bg-white dark:hover:text-primary transition cursor-pointer whitespace-nowrap"
      >
        Ver todo
      </button>
    </div>

    <!-- Featured Events -->
    <div id="featured-events">
      <!-- Desktop grid -->
      <div class="hidden md:grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {featuredEvents.map((event) => <EventCard event={event} />)}
      </div>
      <!-- Mobile carousel -->
      <div class="md:hidden">
        <div
          id="featured-carousel"
          class="events-carousel flex gap-4 overflow-x-auto snap-x snap-mandatory -mx-4 px-4 pb-4"
          style="scrollbar-width: none; -ms-overflow-style: none;"
        >
          {featuredEvents.map((event) => (
            <div class="snap-center flex-shrink-0 w-[85vw]">
              <EventCard event={event} />
            </div>
          ))}
        </div>
        <div class="flex justify-center gap-2 mt-2" id="featured-dots">
          {featuredEvents.map((_, i) => (
            <button
              class:list={[
                "w-2.5 h-2.5 rounded-full transition cursor-pointer",
                i === 0 ? "bg-teal" : "bg-slate-300 dark:bg-slate-600",
              ]}
              data-index={i}
              type="button"
            />
          ))}
        </div>
      </div>
    </div>

    <!-- All Events (hidden by default) -->
    <div id="all-events" style="display: none;">
      <!-- Desktop grid -->
      <div class="hidden md:grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {allEvents.map((event) => <EventCard event={event} />)}
      </div>
      <!-- Mobile carousel -->
      <div class="md:hidden">
        <div
          id="all-carousel"
          class="events-carousel flex gap-4 overflow-x-auto snap-x snap-mandatory -mx-4 px-4 pb-4"
          style="scrollbar-width: none; -ms-overflow-style: none;"
        >
          {allEvents.map((event) => (
            <div class="snap-center flex-shrink-0 w-[85vw]">
              <EventCard event={event} />
            </div>
          ))}
        </div>
        <div class="flex justify-center gap-2 mt-2" id="all-dots">
          {allEvents.map((_, i) => (
            <button
              class:list={[
                "w-2.5 h-2.5 rounded-full transition cursor-pointer",
                i === 0 ? "bg-teal" : "bg-slate-300 dark:bg-slate-600",
              ]}
              data-index={i}
              type="button"
            />
          ))}
        </div>
      </div>
    </div>

    <!-- Bottom toggle button -->
    <div class="flex justify-center mt-10">
      <button
        id="toggle-events-btn-bottom"
        class="toggle-events-btn px-6 py-2 rounded-full border-2 border-primary dark:border-white text-primary dark:text-white font-bold text-sm uppercase tracking-wider hover:bg-primary hover:text-white dark:hover:bg-white dark:hover:text-primary transition cursor-pointer whitespace-nowrap"
      >
        Ver todo
      </button>
    </div>
  </div>
</section>

<style>
  .events-carousel::-webkit-scrollbar { display: none; }
</style>

<script is:inline>
  (function () {
    var buttons = document.querySelectorAll(".toggle-events-btn");
    var featuredGrid = document.getElementById("featured-events");
    var allGrid = document.getElementById("all-events");
    var showingAll = false;

    function toggle() {
      showingAll = !showingAll;
      if (showingAll) {
        featuredGrid.style.display = "none";
        allGrid.style.display = "";
        buttons.forEach(function (btn) { btn.textContent = "Ver principales"; });
      } else {
        featuredGrid.style.display = "";
        allGrid.style.display = "none";
        buttons.forEach(function (btn) { btn.textContent = "Ver todo"; });
      }
    }

    buttons.forEach(function (btn) {
      btn.addEventListener("click", toggle);
    });

    // Carousel dot logic
    function setupCarousel(carouselId, dotsId) {
      var carousel = document.getElementById(carouselId);
      var dotsContainer = document.getElementById(dotsId);
      if (!carousel || !dotsContainer) return;

      var dots = dotsContainer.querySelectorAll("button");
      var slides = Array.from(carousel.children);

      function updateDots() {
        if (slides.length === 0) return;
        var slideWidth = slides[0].offsetWidth;
        var gap = 16;
        var idx = Math.round(carousel.scrollLeft / (slideWidth + gap));
        idx = Math.max(0, Math.min(idx, dots.length - 1));
        dots.forEach(function (dot, i) {
          dot.className = "w-2.5 h-2.5 rounded-full transition cursor-pointer " +
            (i === idx ? "bg-teal" : "bg-slate-300 dark:bg-slate-600");
        });
      }

      carousel.addEventListener("scroll", updateDots);

      dots.forEach(function (dot) {
        dot.addEventListener("click", function () {
          var idx = parseInt(dot.getAttribute("data-index"));
          if (slides.length === 0) return;
          var slideWidth = slides[0].offsetWidth;
          var gap = 16;
          carousel.scrollTo({ left: idx * (slideWidth + gap), behavior: "smooth" });
        });
      });
    }

    setupCarousel("featured-carousel", "featured-dots");
    setupCarousel("all-carousel", "all-dots");
  })();
</script>
