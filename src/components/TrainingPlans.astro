---
import { trainingPlans } from "../data/site";

const colorMap: Record<string, { border: string; badge: string; bg: string }> = {
  teal: { border: "border-teal", badge: "bg-teal text-primary", bg: "bg-teal/10" },
  purple: { border: "border-purple", badge: "bg-purple text-white", bg: "bg-purple/10" },
  gold: { border: "border-amber-400", badge: "bg-amber-400 text-primary", bg: "bg-amber-400/10" },
};

// Mobile order: Oro(2) first, Plata(1) second, Básico(0) third
// Desktop order: Básico(0) first, Plata(1) middle, Oro(2) last
const mobileOrder = ["order-3", "order-2", "order-1"];
const desktopOrder = ["md:order-1", "md:order-2", "md:order-3"];
---

<section class="py-20 bg-white dark:bg-slate-900" id="planes">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Heading -->
    <div class="text-center mb-16">
      <h2
        class="text-4xl md:text-6xl font-display uppercase text-primary dark:text-white leading-none mb-4"
      >
        Planes de <span class="text-gradient">Entrenamiento</span>
      </h2>
      <p class="text-lg text-slate-600 dark:text-slate-400 font-light max-w-2xl mx-auto">
        Todos los planes son totalmente personalizados, específicos a tus objetivos y disponibilidad.
        Incluyen pruebas de rendimiento mensuales.
      </p>
    </div>

    <!-- Plans: carousel on mobile, grid on desktop -->
    <div
      id="plans-carousel"
      class="flex gap-6 overflow-x-auto snap-x snap-mandatory -mx-4 px-4 pt-5 pb-4 md:mx-0 md:px-0 md:pt-0 md:pb-0 md:grid md:grid-cols-3 md:overflow-visible md:snap-none"
    >
      {trainingPlans.map((plan, idx) => {
        const colors = colorMap[plan.color] || colorMap.teal;
        return (
          <div
            class:list={[
              "snap-center flex-shrink-0 w-[85vw] md:w-auto md:flex-shrink",
              mobileOrder[idx],
              desktopOrder[idx],
            ]}
          >
            <div
              class:list={[
                "relative flex flex-col rounded-2xl border-2 bg-slate-50 dark:bg-slate-800 p-8 shadow-sm hover:shadow-2xl transition duration-300 h-full",
                colors.border,
                plan.highlighted ? "md:scale-105" : "",
              ]}
            >
              {plan.highlighted && (
                <div class="absolute -top-4 left-1/2 -translate-x-1/2">
                  <span class={`px-4 py-1 rounded-full text-xs font-bold uppercase tracking-wider ${colors.badge}`}>
                    Más Popular
                  </span>
                </div>
              )}

              <!-- Plan Header -->
              <div class="text-center mb-6">
                <span class={`inline-block px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider mb-3 ${colors.badge}`}>
                  {plan.level}
                </span>
                <h3 class="text-3xl font-display uppercase text-primary dark:text-white mb-2">
                  {plan.name}
                </h3>
                <div class="text-4xl font-display text-primary dark:text-white">
                  {plan.price}
                  <span class="text-base font-body text-slate-500 font-normal">/mes</span>
                </div>
              </div>

              <!-- Description -->
              <p class="text-sm text-slate-600 dark:text-slate-400 text-center mb-4">
                {plan.description}
              </p>
              <p class="text-xs text-slate-500 dark:text-slate-500 text-center mb-6 italic">
                {plan.idealFor}
              </p>

              <!-- Features -->
              <div class="flex-1 space-y-3">
                {plan.features.map((feature) => (
                  <div class="flex items-start gap-3">
                    <span class="material-icons text-teal text-sm mt-0.5">check_circle</span>
                    <div>
                      <span class="text-xs font-bold text-primary dark:text-white uppercase tracking-wider">
                        {feature.label}:
                      </span>
                      <span class="text-xs text-slate-600 dark:text-slate-400 ml-1">
                        {feature.value}
                      </span>
                    </div>
                  </div>
                ))}
              </div>

              <!-- CTA -->
              <a
                href={`https://wa.me/528124188170?text=${encodeURIComponent(`Hola, me interesa el plan ${plan.name} de Vetta`)}`}
                target="_blank"
                rel="noopener noreferrer"
                class:list={[
                  "mt-8 block text-center px-6 py-3 rounded-full font-bold uppercase tracking-wider text-sm transition",
                  plan.highlighted
                    ? `${colors.badge} hover:opacity-90 shadow-lg`
                    : "border-2 border-primary dark:border-white text-primary dark:text-white hover:bg-primary hover:text-white dark:hover:bg-white dark:hover:text-primary",
                ]}
              >
                Inscríbete
              </a>
            </div>
          </div>
        );
      })}
    </div>

    <!-- Carousel dots (mobile only) -->
    <div class="flex justify-center gap-2 mt-4 md:hidden" id="plans-dots">
      <button class="w-2.5 h-2.5 rounded-full bg-teal transition cursor-pointer" data-index="0" type="button"></button>
      <button class="w-2.5 h-2.5 rounded-full bg-slate-300 dark:bg-slate-600 transition cursor-pointer" data-index="1" type="button"></button>
      <button class="w-2.5 h-2.5 rounded-full bg-slate-300 dark:bg-slate-600 transition cursor-pointer" data-index="2" type="button"></button>
    </div>
  </div>
</section>

<style>
  #plans-carousel::-webkit-scrollbar { display: none; }
  #plans-carousel { scrollbar-width: none; -ms-overflow-style: none; }
</style>

<script is:inline>
  (function () {
    var carousel = document.getElementById("plans-carousel");
    var dotsContainer = document.getElementById("plans-dots");
    if (!carousel || !dotsContainer) return;

    var dots = dotsContainer.querySelectorAll("button");
    var slides = Array.from(carousel.children);

    function updateDots() {
      var scrollLeft = carousel.scrollLeft;
      if (slides.length === 0) return;
      var slideWidth = slides[0].offsetWidth;
      var gap = 24;
      var idx = Math.round(scrollLeft / (slideWidth + gap));
      idx = Math.max(0, Math.min(idx, dots.length - 1));
      dots.forEach(function (dot, i) {
        dot.className = "w-2.5 h-2.5 rounded-full transition cursor-pointer " +
          (i === idx ? "bg-teal" : "bg-slate-300 dark:bg-slate-600");
      });
    }

    carousel.addEventListener("scroll", updateDots);

    dots.forEach(function (dot) {
      dot.addEventListener("click", function () {
        var idx = parseInt(dot.getAttribute("data-index"));
        if (slides.length === 0) return;
        var slideWidth = slides[0].offsetWidth;
        var gap = 24;
        carousel.scrollTo({ left: idx * (slideWidth + gap), behavior: "smooth" });
      });
    });
  })();
</script>
