---
import { hero } from "../data/site";
---

<div class="relative pt-32 pb-16 md:pt-36 md:pb-24 overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 z-0">
    <div
      class="absolute top-0 right-0 -mr-20 -mt-20 w-96 h-96 rounded-full bg-teal/20 blur-3xl"
    >
    </div>
    <div
      class="absolute bottom-0 left-0 -ml-20 -mb-20 w-80 h-80 rounded-full bg-purple/20 blur-3xl"
    >
    </div>
    <img
      alt="Ciclistas rodando en pelotón"
      class="w-full h-full object-cover opacity-10 dark:opacity-20 grayscale"
      src={hero.backgroundImage}
    />
  </div>

  <!-- Content -->
  <div
    class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row items-center"
  >
    <!-- Text -->
    <div class="w-full md:w-1/2 text-center md:text-left mb-12 md:mb-0">
      <h1
        class="text-5xl sm:text-6xl md:text-8xl font-display uppercase tracking-tight leading-none mb-6"
      >
        <span class="block text-primary dark:text-white">{hero.headingLine1}</span>
        <span class="text-gradient">{hero.headingLine2}</span>
      </h1>
      <p
        class="mt-4 text-lg md:text-xl text-slate-600 dark:text-slate-300 max-w-lg mx-auto md:mx-0 font-light"
      >
        {hero.subtitle}
      </p>
      <div
        class="mt-8 flex flex-col sm:flex-row gap-4 justify-center md:justify-start"
      >
        <a
          class="px-8 py-4 bg-primary text-white font-bold uppercase tracking-widest text-sm rounded hover:bg-slate-800 transition shadow-xl transform hover:-translate-y-1"
          href={hero.ctaPrimary.href}
        >
          {hero.ctaPrimary.label}
        </a>
        <a
          class="px-8 py-4 border-2 border-primary dark:border-white text-primary dark:text-white font-bold uppercase tracking-widest text-sm rounded hover:bg-primary hover:text-white dark:hover:bg-white dark:hover:text-primary transition"
          href={hero.ctaSecondary.href}
        >
          {hero.ctaSecondary.label}
        </a>
      </div>
    </div>

    <!-- Image -->
    <div class="w-full md:w-1/2 relative px-4 sm:px-0">
      <div class="relative w-full aspect-square max-w-sm md:max-w-md mx-auto mb-8 md:mb-0">
        <div
          class="absolute inset-0 bg-gradient-brand rounded-2xl transform rotate-3 opacity-30"
        >
        </div>
        <img
          alt="Ciclista subiendo una montaña"
          class="absolute inset-0 w-full h-full object-cover rounded-2xl shadow-2xl border-4 border-white dark:border-slate-800 transform -rotate-2 hover:rotate-0 transition duration-500"
          src={hero.image}
        />
        <!-- Next Ride Card -->
        <div
          class="absolute -bottom-4 left-0 sm:-bottom-6 sm:-left-6 bg-white dark:bg-slate-800 p-3 sm:p-4 rounded-lg shadow-xl border border-slate-100 dark:border-slate-700 flex items-center gap-3 animate-bounce"
          style="animation-duration: 3s;"
        >
          <span class="material-icons text-teal text-2xl sm:text-3xl">bolt</span>
          <div>
            <p
              class="text-xs text-slate-500 dark:text-slate-400 uppercase font-bold tracking-wider"
            >
              {hero.nextRide.label}
            </p>
            <p class="text-primary dark:text-white font-display text-lg sm:text-xl uppercase">
              {hero.nextRide.name}
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
