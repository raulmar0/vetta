---
import { methodology } from "../data/site";
---

<section class="py-20 bg-bg-light dark:bg-bg-dark" id="metodologia">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Heading -->
    <div class="text-center mb-16">
      <h2
        class="text-4xl md:text-6xl font-display uppercase text-primary dark:text-white leading-none mb-4"
      >
        Metodología <span class="text-gradient">Vetta</span>
      </h2>
      <p class="text-lg text-purple font-bold uppercase tracking-wider mb-4">
        {methodology.subtitle}
      </p>
      <p class="text-slate-600 dark:text-slate-400 max-w-3xl mx-auto leading-relaxed">
        {methodology.description}
      </p>
    </div>

    <!-- Macrocycle Phases -->
    <div class="mb-16">
      <h3 class="text-2xl font-display uppercase text-primary dark:text-white text-center mb-8">
        Estructura de <span class="text-gradient">Macrociclos</span>
      </h3>

      <div class="flex flex-col items-center gap-3">
        {methodology.phases.map((phase, i) => (
          <>
            <span
              class:list={[
                "px-5 py-2.5 md:py-3 rounded-full font-bold text-sm uppercase tracking-wider border-2 w-full max-w-xs text-center",
                i % 2 === 0
                  ? "border-teal text-teal bg-teal/10"
                  : "border-purple text-purple bg-purple/10",
              ]}
            >
              {phase}
            </span>
            {i < methodology.phases.length - 1 && (
              <span class="material-icons text-slate-300 dark:text-slate-600 text-lg">
                arrow_downward
              </span>
            )}
          </>
        ))}
      </div>
    </div>

    <!-- Tools Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6">
      {methodology.tools.map((tool, i) => (
        <div class="text-center bg-white dark:bg-slate-800 p-6 rounded-2xl border border-slate-100 dark:border-slate-700 shadow-sm hover:shadow-lg transition duration-300">
          <div
            class:list={[
              "w-16 h-16 rounded-2xl flex items-center justify-center mx-auto mb-4",
              i % 2 === 0 ? "bg-teal/10 text-teal" : "bg-purple/10 text-purple",
            ]}
          >
            <span class="material-icons text-3xl">{tool.icon}</span>
          </div>
          <h4 class="font-bold text-primary dark:text-white uppercase tracking-wide text-sm mb-2">
            {tool.name}
          </h4>
          <p class="text-xs text-slate-600 dark:text-slate-400">
            {tool.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
